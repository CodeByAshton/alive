{
  "name": "vault",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "description": "An AI-native vault that follows you across devices.",
  "author": "CodeByAshton",
  "scripts": {
    "dev": "concurrently -n server,web \"node server/index.mjs\" \"vite\"",
    "server": "node server/index.mjs",
    "node-harness": "node agent/vault-node.mjs",
    "web": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "dist:desktop": "npm run build && electron-builder",
    "ios:sync": "npm run build && cap sync ios",
    "e2e": "node scripts/e2e.mjs",
    "test:auth": "node scripts/test-auth.mjs",
    "smoke:supabase": "node scripts/smoke-supabase.mjs"
  },
  "build": {
    "appId": "com.codebyashton.vault",
    "productName": "Vault",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**",
      "dist/**",
      "server/**",
      "agent/**",
      "shared/**",
      "!server/data/**"
    ],
    "asarUnpack": [
      "server/**",
      "agent/**",
      "shared/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@supabase/supabase-js": "^2.110.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "dexie": "^4.0.8",
    "express": "^4.21.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-2d": "^1.25.5",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
